NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# "local" or "server" — shows a colored badge in the topbar
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_APP_ENV_LABEL=LOCAL

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:sabarinathan.ravindran@gmail.com

# WhatsApp Cloud API (Meta for Developers)
# WHATSAPP_VERIFY_TOKEN — any secret string you choose; enter it in Meta webhook setup
# WHATSAPP_ACCESS_TOKEN — permanent token from System User in Meta Business Manager
# WHATSAPP_PHONE_NUMBER_ID — found in WhatsApp Manager > Phone Numbers
WHATSAPP_VERIFY_TOKEN=your-verify-token
WHATSAPP_ACCESS_TOKEN=your-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=694983870354081
