NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# "local" or "server" — shows a colored badge in the topbar
NEXT_PUBLIC_APP_ENV=local
NEXT_PUBLIC_APP_ENV_LABEL=LOCAL

# Web Push (VAPID) — generate with: npx web-push generate-vapid-keys --json
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:sabarinathan.ravindran@gmail.com
